{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quill",
  "version": "0.7.4",
  "identifier": "com.wycstudios.quill",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Quill",
        "width": 1440,
        "height": 960,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/Library/Mobile Documents/iCloud~com~wycstudios~quill/Documents/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yicheng47/quill/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3QjYzODMyNDFGNTY5Q0YKUldUUGFmVkJNamkyWnhoejBQb2hMYnhmcUZaSGxva2FZT1Q0OTJveWV0U25vVkRDeEtMY3hwenYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "Entitlements.plist",
      "files": {
        "embedded.provisionprofile": "embedded.provisionprofile"
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    }
  }
}
