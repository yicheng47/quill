                              "fill": "$text-primary",
                              "content": "Interesting a lot of current society",
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "p0z8L",
                      "name": "Assistant msg 2",
                      "fill": "$bg-surface",
                      "cornerRadius": 8,
                      "stroke": {
                        "align": "inside",
                        "thickness": 1,
                        "fill": "$border"
                      },
                      "layout": "vertical",
                      "gap": 6,
                      "padding": 13,
                      "children": [
                        {
                          "type": "text",
                          "id": "XpeFv",
                          "name": "assist2P1",
                          "fill": "$text-primary",
                          "textGrowth": "fixed-width",
                          "width": 344,
                          "content": "Absolutely — you're picking up on one of the novel's biggest points.",
                          "lineHeight": 1.4,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "sGG43",
                          "name": "assist2P2",
                          "fill": "$text-primary",
                          "textGrowth": "fixed-width",
                          "width": 344,
                          "content": "I think you're starting to say: a lot of current society still works like this—people are made to \"prove\" themselves through stress, rejection, and grind before they're accepted.",
                          "lineHeight": 1.4,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
